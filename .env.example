# DirectKey - Environment Variables
# Copy this file to .env.local and fill in your values

# WhatsApp Number (international format, no + or spaces)
NEXT_PUBLIC_WHATSAPP_NUMBER=905XXXXXXXXX

# Admin secret for /api/leads GET endpoint (change this!)
ADMIN_SECRET=your-secret-key-here

# ─── OPTIONAL: Upgrade from JSON file to PostgreSQL ───────────────────────────
# Uncomment when ready to use Vercel Postgres or Neon DB
# DATABASE_URL=postgresql://user:password@host:5432/directkey

# ─── OPTIONAL: Email notifications for new leads ──────────────────────────────
# RESEND_API_KEY=re_xxxxxxxxxxxx
# NOTIFICATION_EMAIL=your@email.com
